# =============================================================================
# AgentFarm Optimizer — copy to `.env` and paste your keys
#   cp .env.example .env
# =============================================================================

# --- External APIs ---

OPENWEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=
OPENAI_API_KEY=

# --- Database & cache (defaults work with docker-compose Postgres + Redis) ---

DATABASE_URL=postgresql+asyncpg://agentfarm:agentfarm@localhost:5432/agentfarm
REDIS_URL=redis://localhost:6379/0

# --- Optional ---
# DATA_SEED_DIR=
# VRP_TIME_LIMIT=30
# MAX_RETRIES=2
# PLANNING_TEMP=0.0
# ADVISOR_TEMP=0.3
