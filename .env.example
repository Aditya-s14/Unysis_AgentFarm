# =============================================================================
# AgentFarm Optimizer — copy to `.env` and paste your keys
#   cp .env.example .env
# =============================================================================

# --- External APIs ---

OPENWEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=
OPENAI_API_KEY=

# --- Database & cache (defaults work with docker-compose Postgres + Redis) ---

DATABASE_URL=postgresql+asyncpg://agentfarm:agentfarm@localhost:5432/agentfarm
REDIS_URL=redis://localhost:6379/0

# --- Road routing ---
#
# Distance chain priority (only the first one with credentials is used):
#   1. OpenRouteService (hosted, free)   — set ORS_API_KEY below
#   2. Self-hosted OSRM                  — opt-in, see README
#   3. Google Distance Matrix            — set GOOGLE_MAPS_API_KEY above
#   4. Haversine x1.3 fallback           — always available
#
# OpenRouteService (NOT OpenRouter — different service):
# Sign up free at https://openrouteservice.org → My Account → Generate Key.
# Free tier: 2000 directions/day, no card required.
ORS_API_KEY=

# Self-hosted OSRM (optional, only when running with --profile self-host):
# Compose injects OSRM_URL automatically for the optional `osrm` service; this
# line is only needed if you run the backend outside Docker against a local OSRM.
OSRM_URL=

# --- Optional ---
# DATA_SEED_DIR=
# VRP_TIME_LIMIT=30
# MAX_RETRIES=2
# PLANNING_TEMP=0.0
# ADVISOR_TEMP=0.3

# --- Farmer notifications (SMS / voice fallback for offline farms) ---
# NOTIFY_ENABLED=false
# NOTIFY_PROVIDER=mock
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=KISANM
# MSG91_TEMPLATE_ID=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# NOTIFY_SPOILAGE_HOURS=24
# NOTIFY_VOICE_SPOILAGE_HOURS=12
# NOTIFY_ALL_ROUTED=false
# NOTIFY_REQUIRE_APPROVAL=true
# FIELD_OFFICER_PHONE=
